# Entornos y dependencias
node_modules/
__pycache__/
*.pyc
.venv/
venv/
env/

# IDE y Sistema Operativo
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Artefactos
dist/
build/
*.egg-info/
coverage/

# .agents es donde residen las reglas de los agentes, por lo tanto NO lo ignoramos.
# Sin embargo, los logs generados por ellos sí (evidencia local, no versionada):
.agents/logs/*
# Excepcion: la plantilla del envelope de atestacion SI se distribuye con el
# template (mismo patron que docs/reports/TEMPLATE-REPORT.md).
!.agents/logs/TEMPLATE-REPORT.md

# Artefacto derivado del exportador gate-nativo (CCDD nivel 2): se regenera
# desde scripts/export_gate_contract.py; no es fuente. Vive en la raiz del
# repo como <task>.gate.md (el gate real exige rutas target/tests sin "..").
*.gate.md

# Binarios compilados de la Piel 3 (TUI Go): se regeneran con
# `go build -o lazykdd(.exe) .` desde tui/.
tui/lazykdd
tui/lazykdd.exe
tui/*.test
